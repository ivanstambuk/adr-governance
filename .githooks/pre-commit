#!/usr/bin/env bash
# =============================================================================
# Pre-commit hook: Auto-render ADR Markdown
# =============================================================================
#
# When ADR YAML files in architecture-decision-log/ or examples-reference/
# are staged, this hook automatically renders them to human-friendly Markdown
# in their respective rendered/ directories and regenerates the decision log index.
#
# Install once per clone:
#   git config core.hooksPath .githooks
#
# Requires: python3, pyyaml
# =============================================================================

set -e

# Only trigger if ADR YAML files are staged in either directory
STAGED_ADL=$(
    git diff --cached --name-only -- \
        "architecture-decision-log/*.yaml" \
        "architecture-decision-log/*.yml" 2>/dev/null || true
)
STAGED_EXAMPLES=$(
    git diff --cached --name-only -- \
        "examples-reference/*.yaml" \
        "examples-reference/*.yml" 2>/dev/null || true
)

if [ -z "$STAGED_ADL" ] && [ -z "$STAGED_EXAMPLES" ]; then
    exit 0
fi

# Verify dependencies — warn and skip gracefully if missing
if ! command -v python3 &>/dev/null; then
    echo "⚠️  python3 not found — skipping ADR rendering"
    exit 0
fi

if ! python3 -c "import yaml" 2>/dev/null; then
    echo "⚠️  pyyaml not installed — skipping ADR rendering (pip install pyyaml)"
    exit 0
fi

# Render architecture-decision-log/ if changed
if [ -n "$STAGED_ADL" ]; then
    echo "🔄 ADR changes detected in architecture-decision-log/ — rendering Markdown..."
    python3 scripts/render-adr.py \
        --output-dir "rendered/" \
        --generate-index \
        "architecture-decision-log/"
    git add "rendered/"
fi

# Render examples-reference/ if changed
if [ -n "$STAGED_EXAMPLES" ]; then
    echo "🔄 ADR changes detected in examples-reference/ — rendering Markdown..."
    python3 scripts/render-adr.py \
        --output-dir "examples-reference/rendered/" \
        --generate-index \
        "examples-reference/"
    git add "examples-reference/rendered/"
fi

echo "✅ Rendered ADR Markdown staged for commit"

# =============================================================================
# Auto-regenerate llms-full.txt if any source doc changed
# =============================================================================

STAGED_DOCS=""
if [ -x "scripts/generate-llms-full.sh" ]; then
    mapfile -t LLMS_FULL_SOURCES < <(scripts/generate-llms-full.sh --print-sources)
    for src in "${LLMS_FULL_SOURCES[@]}"; do
        if git diff --cached --name-only -- "$src" 2>/dev/null | grep -q .; then
            STAGED_DOCS="yes"
            break
        fi
    done
fi

if [ -n "$STAGED_DOCS" ]; then
    echo "🔄 Documentation changes detected — regenerating llms-full.txt..."
    if [ -x "scripts/generate-llms-full.sh" ]; then
        scripts/generate-llms-full.sh
        git add "llms-full.txt"
    else
        echo "⚠️  scripts/generate-llms-full.sh not found or not executable — skipping"
    fi
fi
